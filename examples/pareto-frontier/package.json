    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.489",
    "roughjs": "4.6.6"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "typescript": "5.9.3"
  }
}
